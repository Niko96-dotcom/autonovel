# OpenAI-compatible key (required for writing, evaluation, and review)
OPENAI_API_KEY=sk-...

# Optional OpenAI-compatible endpoint override
# Examples: OpenRouter, LM Studio, vLLM, llama.cpp server
OPENAI_BASE_URL=

# Model slots
WRITER_MODEL=gpt-4o
REVIEWER_MODEL=gpt-4o

# fal.ai key for image generation (optional)
FAL_KEY=your-fal-api-key-here

# ElevenLabs API key for audiobook generation (optional)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
